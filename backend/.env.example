# Local dev defaults to sqlite - no setup needed, just run the server.
# For Postgres locally: DATABASE_URL=postgresql://user:password@localhost:5432/gym_progress
DATABASE_URL=sqlite:///./gym.db

# Change this in production - Render's render.yaml auto-generates one for you.
SECRET_KEY=dev-secret-change-me-in-production

ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of allowed frontend origins, e.g.:
# CORS_ORIGINS=https://your-app.netlify.app,http://localhost:5500
CORS_ORIGINS=*
