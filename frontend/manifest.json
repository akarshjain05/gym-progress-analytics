{
  "name": "IRONLOG — Gym Progress Analytics",
  "short_name": "IRONLOG",
  "description": "Track your lifts, weight, and nutrition. Real trend analysis.",
  "start_url": "/login.html",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "background_color": "#1e2327",
  "theme_color": "#1e2327",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "categories": ["fitness", "health", "sports"],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "shortcuts": [
    {
      "name": "Log Workout",
      "short_name": "Workout",
      "description": "Start logging a new workout session",
      "url": "/workout.html",
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Log Weight",
      "short_name": "Weight",
      "description": "Log today's body weight",
      "url": "/weight.html",
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "View your progress dashboard",
      "url": "/dashboard.html",
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Log Nutrition",
      "short_name": "Nutrition",
      "description": "Log today's calories and macros",
      "url": "/nutrition.html",
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/nutrition.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text"
    }
  },
