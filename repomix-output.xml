/* ── Stats row ───────────────────────────────────────────── */
.lifts-stats-row {
  display: grid; grid-template-columns: 1fr 1fr 1fr;
  gap: 12px; margin-bottom: 16px;
}
@media (max-width: 600px) {
  .lifts-stats-row { grid-template-columns: 1fr 1fr; }
  .lifts-stats-row .stat-card:last-child { grid-column: 1 / -1; }
}
.stat-card {
  background: var(--surface, #2a2f35);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px; padding: 16px 18px;
}
.stat-label {
  font-size: 10px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--text-secondary, #a09880); margin-bottom: 8px;
}
.stat-big {
  font-size: 28px; font-weight: 800;
  color: var(--text-primary, #e8e0d5); line-height: 1; margin-bottom: 4px;
}
.stat-unit { font-size: 16px; font-weight: 400; color: var(--text-secondary, #a09880); }
.stat-sub { font-size: 12px; color: var(--text-secondary, #a09880); }
.stat-sub.positive { color: #27ae60; }
.stat-sub.negative { color: #c0392b; }
.stat-sub.neutral { color: #a09880; }

/* ── Strength level badge ────────────────────────────────── */
.strength-level-badge {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 8px 14px; border-radius: 8px; margin-top: 4px;
}

/* ── Strength scale card ─────────────────────────────────── */
.strength-scale-card {
  background: var(--surface, #2a2f35);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px; padding: 16px 18px; margin-bottom: 16px;
}
.strength-scale-title {
  font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--text-secondary, #a09880); margin-bottom: 12px;
}
.strength-scale { position: relative; margin-bottom: 4px; }
.scale-track {
  display: flex; height: 10px; border-radius: 5px;
  overflow: visible; position: relative;
}
.scale-seg {
  height: 10px; transition: opacity 0.3s;
}
.scale-seg:first-child { border-radius: 5px 0 0 5px; }
.scale-seg.active { opacity: 1 !important; }
.scale-marker {
  position: absolute; top: -4px;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center;
  pointer-events: none;
}
.scale-marker-arrow {
  width: 0; height: 0;
  border-left: 6px solid transparent;
  border-right: 6px solid transparent;
  border-top: 8px solid #e8e0d5;
}
.scale-marker-label {
  font-size: 10px; font-weight: 700;
  color: #e8e0d5; white-space: nowrap;
