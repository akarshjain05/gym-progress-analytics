from app.database import SessionLocal
from app.models import Exercise

def main():
    db = SessionLocal()
    
    # 1. Merge muscle_group = 'core' into 'abs'
    updated_muscle = db.query(Exercise).filter(Exercise.muscle_group == 'core').update({"muscle_group": "abs"})
    
