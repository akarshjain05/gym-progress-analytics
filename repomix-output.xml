def classify_bodyweight_exercise(exercise_name: str, gender: str, reps: int) -> Optional[str]:
    """
    For bodyweight exercises (pull-up, chin-up, dip, hanging leg raise, plank).
    reps = max clean reps performed (or seconds for plank).
    Returns beginner/novice/intermediate/advanced/elite or None.
    """
    bw_key = BODYWEIGHT_EXERCISE_MAP.get(exercise_name.strip().lower())
    if not bw_key or gender not in BODYWEIGHT_REP_STANDARDS:
        return None
    table = BODYWEIGHT_REP_STANDARDS[gender].get(bw_key)
    if not table:
        return None
    level = None
    for tier in ["beginner", "novice", "intermediate", "advanced", "elite"]:
        if reps >= table[tier]:
            level = tier
    return level


def classify_strength_level(
    exercise_name: str,
    gender: str,
    bodyweight_kg: float,
    one_rm_kg: float,
) -> Optional[str]:
    """
    Returns one of: beginner/novice/intermediate/advanced/elite or None.

    For bodyweight exercises (pull-up, dip etc.), pass reps as one_rm_kg
    and this will route correctly to the reps-based classifier.
    For weighted exercises, one_rm_kg is the estimated 1RM.
    """
    name_lower = exercise_name.strip().lower()
    std_key = EXERCISE_TO_STANDARD.get(name_lower)

    # std_key is None = either bodyweight exercise or not in our list
    if std_key is None:
        # Check if it's a bodyweight exercise
        if name_lower in BODYWEIGHT_EXERCISE_MAP:
            # one_rm_kg is being used as reps here for bodyweight
            return classify_bodyweight_exercise(name_lower, gender, int(one_rm_kg))
        return None

    if gender not in STRENGTH_STANDARDS or bodyweight_kg <= 0:
        return None
    if gender == "other":
        return None

    standards = STRENGTH_STANDARDS[gender]
    if std_key not in standards:
        return None

    ratio = one_rm_kg / bodyweight_kg
    table = standards[std_key]
    level = None
    for tier in ["beginner", "novice", "intermediate", "advanced", "elite"]:
        if ratio >= table[tier]:
            level = tier
    return level


def get_strength_standard_info(
    exercise_name: str,
    gender: str,
    bodyweight_kg: float,
) -> Optional[dict]:
    """
    Returns absolute kg breakpoints for frontend visual scale.
    For bodyweight exercises returns rep breakpoints instead.
    """
    name_lower = exercise_name.strip().lower()
    std_key = EXERCISE_TO_STANDARD.get(name_lower)

    if std_key is None:
        # Bodyweight exercise — return rep breakpoints
        bw_key = BODYWEIGHT_EXERCISE_MAP.get(name_lower)
        if bw_key and gender in BODYWEIGHT_REP_STANDARDS:
            table = BODYWEIGHT_REP_STANDARDS[gender].get(bw_key)
            if table:
                unit = "seconds" if "plank" in bw_key else "reps"
                return {tier: f"{val} {unit}" for tier, val in table.items()}
        return None

    if gender not in STRENGTH_STANDARDS or bodyweight_kg <= 0:
        return None

    standards = STRENGTH_STANDARDS[gender]
    if std_key not in standards:
        return None

    table = standards[std_key]
    return {
        tier: round(ratio * bodyweight_kg, 1)
        for tier, ratio in table.items()
    }


# ---------------------------------------------------------------------------
# STRENGTH PERCENTILE
#
# Converts the discrete 5-tier standards above into a smooth 0-100
# percentile, so instead of "you're intermediate" we can say "stronger
# than 63% of lifters your bodyweight."
#
# Percentile anchors per tier follow the same convention the underlying
# ratio tables are sourced from (Symmetric Strength / StrengthLevel-style
# population data): beginner sits near the bottom of "has trained at all,"
# elite sits near the top of the whole lifting population, not just gym-goers.
#
#   beginner -> 5th percentile   (just started training)
#   novice -> 20th percentile
#   intermediate -> 50th percentile   (median trained lifter)
#   advanced -> 80th percentile
#   elite -> 95th percentile   (top 5% of lifters)
#
# Between two known tiers we interpolate percentile linearly against the
# ratio. Below beginner or above elite we extrapolate using the nearest
# segment's slope, then clamp to [1, 99] — nobody sees a bare 0 or 100,
# since real population tails always extend a bit further both ways.
# ---------------------------------------------------------------------------

TIER_PERCENTILES = {
    "beginner": 5,
    "novice": 20,
    "intermediate": 50,
    "advanced": 80,
    "elite": 95,
}
TIER_ORDER = ["beginner", "novice", "intermediate", "advanced", "elite"]


def _interpolate_percentile(value: float, table: dict) -> float:
    """
    Shared interpolation core. `table` maps tier name -> threshold value
    (either a bodyweight ratio or a rep count), already sorted ascending
    by TIER_ORDER. Returns a percentile clamped to [1, 99].
    """
    points = [(table[t], TIER_PERCENTILES[t]) for t in TIER_ORDER]

    # Below the lowest tier: extrapolate down from the first segment's slope
    if value <= points[0][0]:
        (x0, p0), (x1, p1) = points[0], points[1]
        if x1 == x0:
            return max(1.0, p0)
        slope = (p1 - p0) / (x1 - x0)
        pct = p0 + slope * (value - x0)
        return max(1.0, min(pct, p0))

    # Above the highest tier: extrapolate up from the last segment's slope
    if value >= points[-1][0]:
        (x0, p0), (x1, p1) = points[-2], points[-1]
        if x1 == x0:
            return min(99.0, p1)
        slope = (p1 - p0) / (x1 - x0)
        pct = p1 + slope * (value - x1)
        return min(99.0, max(pct, p1))

    # Between two known tiers: plain linear interpolation
    for i in range(len(points) - 1):
        (x0, p0), (x1, p1) = points[i], points[i + 1]
        if x0 <= value <= x1:
            if x1 == x0:
                return p0
            frac = (value - x0) / (x1 - x0)
            return p0 + frac * (p1 - p0)

    return 50.0  # unreachable, safe fallback


def get_strength_percentile(
    exercise_name: str,
    gender: str,
    bodyweight_kg: float,
    one_rm_kg: float,
) -> Optional[dict]:
    """
    Returns {"percentile": float, "tier": str} for a lift, or None if the
    exercise/gender combo isn't in our standards.

    For bodyweight exercises (pull-up, dip, plank, etc.), pass reps
    (or seconds, for plank) as one_rm_kg — same calling convention as
    classify_strength_level.

    gender must be "male" or "female" — the underlying tables don't cover
    "other", since population strength-distribution data isn't collected
    that way; callers should fall back to not showing a percentile rather
    than guessing.
    """
    if gender not in ("male", "female"):
        return None

    name_lower = exercise_name.strip().lower()
    std_key = EXERCISE_TO_STANDARD.get(name_lower)

    if std_key is None:
        bw_key = BODYWEIGHT_EXERCISE_MAP.get(name_lower)
        if not bw_key or gender not in BODYWEIGHT_REP_STANDARDS:
            return None
        table = BODYWEIGHT_REP_STANDARDS[gender].get(bw_key)
        if not table:
            return None
        percentile = _interpolate_percentile(one_rm_kg, table)
        tier = classify_bodyweight_exercise(name_lower, gender, int(one_rm_kg))
        return {"percentile": round(percentile, 1), "tier": tier}

    if bodyweight_kg <= 0 or std_key not in STRENGTH_STANDARDS.get(gender, {}):
        return None

    ratio = one_rm_kg / bodyweight_kg
    table = STRENGTH_STANDARDS[gender][std_key]
    percentile = _interpolate_percentile(ratio, table)
    tier = classify_strength_level(exercise_name, gender, bodyweight_kg, one_rm_kg)
    return {"percentile": round(percentile, 1), "tier": tier}


# ---------------------------------------------------------------------------
# BMI & Body Composition
# ---------------------------------------------------------------------------

def calculate_bmi(weight_kg: float, height_cm: float) -> dict:
    if height_cm <= 0 or weight_kg <= 0:
        return {"value": 0.0, "category": "Invalid"}
    
    height_m = height_cm / 100
    bmi = round(weight_kg / (height_m ** 2), 1)
    
    if bmi < 18.5:
        category = "Underweight"
    elif bmi < 25:
        category = "Normal"
    elif bmi < 30:
        category = "Overweight"
    else:
        category = "Obese"
        
    return {"value": bmi, "category": category}

def calculate_ideal_body_weight(height_cm: float, gender: str) -> Optional[float]:
    """Devine formula"""
    if height_cm < 152.4:  # Formula applies to heights > 5 feet
        return None
    inches_over_5_ft = (height_cm - 152.4) / 2.54
    if gender == "male":
        return round(50.0 + 2.3 * inches_over_5_ft, 1)
    elif gender == "female":
        return round(45.5 + 2.3 * inches_over_5_ft, 1)
    return None

def calculate_lean_body_mass(weight_kg: float, height_cm: float, gender: str) -> Optional[float]:
    """Boer formula"""
    if gender == "male":
        return round((0.407 * weight_kg) + (0.267 * height_cm) - 19.2, 1)
    elif gender == "female":
        return round((0.252 * weight_kg) + (0.473 * height_cm) - 48.3, 1)
    return None

def calculate_ffmi(lbm_kg: float, height_cm: float) -> dict:
    if height_cm <= 0 or lbm_kg <= 0:
        return {"value": 0.0, "normalized": 0.0, "category": "Invalid"}
    
    height_m = height_cm / 100
    ffmi = lbm_kg / (height_m ** 2)
    normalized_ffmi = ffmi + 6.1 * (1.8 - height_m)
    
    val = round(ffmi, 1)
    norm_val = round(normalized_ffmi, 1)
    
    if norm_val < 18:
        cat = "Below Average"
    elif norm_val < 20:
        cat = "Average"
    elif norm_val < 22:
        cat = "Above Average"
    elif norm_val < 23:
        cat = "Excellent"
    elif norm_val < 25:
        cat = "Superior"
    else:
        cat = "Suspicious (Natty Limit ~25)"
        
    return {"value": val, "normalized": norm_val, "category": cat}


# ---------------------------------------------------------------------------
# Powerlifting Scores (Wilks 2020 & DOTS)
# ---------------------------------------------------------------------------

def calculate_wilks(weight_kg: float, total_kg: float, gender: str) -> float:
    """Wilks 2020 formula"""
    if weight_kg <= 0 or total_kg <= 0:
        return 0.0
        
    if gender == "male":
        a = 47.46178854
        b = 8.472061379
        c = 0.07369410346
        d = -1.395833811e-3
        e = 7.076659730e-6
        f = -1.208043364e-8
    elif gender == "female":
        a = -125.4255398
        b = 13.71219419
        c = -0.03307250631
        d = -1.050400051e-3
        e = 9.387738815e-6
        f = -2.333461388e-8
    else:
        return 0.0

    w = weight_kg
    denominator = a + (b * w) + (c * w**2) + (d * w**3) + (e * w**4) + (f * w**5)
    if denominator == 0:
        return 0.0
    return round((600 / denominator) * total_kg, 2)


def calculate_dots(weight_kg: float, total_kg: float, gender: str) -> float:
    """DOTS formula"""
    if weight_kg <= 0 or total_kg <= 0:
        return 0.0
        
    w = weight_kg
    if gender == "male":
        a = -307.75076
        b = 24.0900756
        c = -0.1918759221
        d = 0.0007391293
        e = -0.000001093
    elif gender == "female":
        a = -57.96288
        b = 13.6175032
        c = -0.1126655495
        d = 0.0005158568
        e = -0.000001070
    else:
        return 0.0

    denominator = a + (b * w) + (c * w**2) + (d * w**3) + (e * w**4)
    if denominator == 0:
        return 0.0
    return round((500 / denominator) * total_kg, 2)


# ---------------------------------------------------------------------------
# Macro Calculator
# ---------------------------------------------------------------------------

def calculate_macros(calories: float, goal: str) -> dict:
    """
    Standard splits based on goal.
    cut: High protein to preserve muscle (40P / 30C / 30F)
    maintain: Balanced (30P / 40C / 30F)
    bulk: High carb for energy/growth (25P / 50C / 25F)
    """
    if calories <= 0:
        return {"protein_g": 0, "carbs_g": 0, "fat_g": 0}
        
    if goal == "cut":
        p_ratio = 0.40
        c_ratio = 0.30
        f_ratio = 0.30
    elif goal == "bulk":
        p_ratio = 0.25
        c_ratio = 0.50
        f_ratio = 0.25
    else: # maintain
        p_ratio = 0.30
        c_ratio = 0.40
        f_ratio = 0.30
        
    # 4 kcal/g for Protein and Carbs, 9 kcal/g for Fat
    p_kcal = calories * p_ratio
    c_kcal = calories * c_ratio
    f_kcal = calories * f_ratio
    
    return {
        "protein_g": round(p_kcal / 4),
        "carbs_g": round(c_kcal / 4),
        "fat_g": round(f_kcal / 9),
    }
