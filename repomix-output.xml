<link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png">
<link rel="stylesheet" href="/css/mobile.css?v=104">
<title>Forgot Password — IRONLOG</title>
<link rel="stylesheet" href="css/style.css?v=104">
</head>
<body>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="brand-mark">IL</div>
      <h1>Reset password</h1>
      <p>Enter your account email and we'll send you a reset link.</p>
    </div>

    <div id="alertSlot"></div>

    <form id="forgotForm">
      <div class="field">
        <label for="fpEmail">Email</label>
        <input id="fpEmail" type="email" autocomplete="email" required>
      </div>
      <button class="btn btn-primary btn-block" type="submit" id="fpSubmitBtn">Send reset link</button>
    </form>

    <div class="auth-switch">
      <a href="login.html">Back to log in</a>
    </div>
  </div>
</div>

<script src="js/config.js?v=104"></script>
<script src="js/api.js?v=104"></script>
<script>
const forgotForm = document.getElementById("forgotForm");
const alertSlot = document.getElementById("alertSlot");

function setAlert(message, type = "error") {
  alertSlot.innerHTML = message ? `<div class="alert alert-${type}">${message}</div>` : "";
}

forgotForm.addEventListener("submit", async (e) => {
  e.preventDefault();
  setAlert("");
  const btn = document.getElementById("fpSubmitBtn");
  btn.disabled = true; btn.textContent = "Sending…";
  try {
    const response = await Api.forgotPassword(document.getElementById("fpEmail").value.trim());
    forgotForm.style.display = "none";
    
    // For demo/portfolio purposes: if the backend didn't actually send an email
    // and instead returned the link to us, show it directly so the user can test.
    if (response && response.reset_link) {
      setAlert(`
        <div style="margin-bottom: 12px;">Since no email service is configured on this server, here is your reset link:</div>
        <a href="${response.reset_link}" class="btn btn-primary" style="display:inline-block;text-decoration:none;">Reset Password</a>
      `, "success");
    } else {
      setAlert("If that email is registered, a reset link is on its way. Check your inbox.", "success");
    }
  } catch (err) {
    setAlert(err.message || "Something went wrong. Try again.");
    btn.disabled = false; btn.textContent = "Send reset link";
  }
});
</script>
<script src="/js/pwa.js?v=104"></script>
</body>
</html>
