/* ── Section blocks ──────────────────────────────────────── */
.section-block {
  margin-bottom: 24px;
}
.section-label {
  font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--text-secondary, #a09880);
  margin-bottom: 10px; padding: 0 2px;
}

/* ── Sessions grouped by date ────────────────────────────── */
.session-group {
