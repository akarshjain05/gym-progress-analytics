<meta name="apple-mobile-web-app-title" content="IRONLOG">
<link rel="manifest" href="/manifest.json">
<link rel="apple-touch-icon" href="/icons/icon-192.png">
<link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152.png">
<link rel="apple-touch-icon" sizes="144x144" href="/icons/icon-144.png">
<link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png">
<link rel="shortcut icon" href="/icons/icon-96.png">
<title>Goals — IRONLOG</title>
<link rel="stylesheet" href="css/theme.css?v=104">
<link rel="stylesheet" href="css/style.css?v=104">
<link rel="stylesheet" href="css/mobile.css?v=104">
<link rel="stylesheet" href="css/polish.css?v=104">
<style>
  .goal-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px;
    border-bottom: 1px solid var(--border);
  }
  .goal-card:last-child { border-bottom: none; }
  .goal-card-completed { opacity: 0.6; }
  .goal-details { flex-grow: 1; margin-left: 12px; }
  .goal-title { font-weight: 600; font-size: 15px; margin-bottom: 4px; }
  .goal-subtitle { font-size: 13px; color: var(--text-tertiary); }
  .goal-actions { display: flex; gap: 8px; }
  .badge-goal { padding: 2px 8px; font-size: 11px; border-radius: 12px; font-weight: 600; text-transform: uppercase; }
  .badge-lift { background: rgba(52,152,219,0.15); color: #3498db; }
  .badge-weight { background: rgba(155,89,182,0.15); color: #9b59b6; }
  .badge-nutrition { background: rgba(46,204,113,0.15); color: #2ecc71; }
  .badge-frequency { background: rgba(241,196,15,0.15); color: #f1c40f; }
  #pageHeaderActions {
    flex-grow: 1;
  }
  .goals-header-actions {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 32px;
    width: 100%;
    margin-top: 8px;
  }
  @media (max-width: 768px) {
    .goals-header-actions {
      justify-content: space-between;
      gap: 8px;
    }
  }
  .goal-checkbox {
    -webkit-appearance: none;
    appearance: none;
    width: 22px !important;
    height: 22px !important;
    min-width: 22px !important;
    min-height: 22px !important;
    max-width: 22px !important;
    max-height: 22px !important;
    flex-shrink: 0;
    border: 2px solid var(--text-tertiary, #6b7280);
    border-radius: 50%;
    background: transparent;
    cursor: pointer;
    margin: 0;
    position: relative;
    transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
    outline: none !important;
    -webkit-tap-highlight-color: transparent;
  }
  .goal-checkbox:active {
    transform: scale(0.9);
  }
  .goal-checkbox:checked {
    background: var(--primary, #c0392b);
    border-color: var(--primary, #c0392b);
    transform: scale(1);
    animation: check-pop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .goal-checkbox:checked::after {
    content: '';
    position: absolute;
    top: 45%;
    left: 50%;
    width: 5px;
    height: 10px;
    border: solid #fff;
    border-width: 0 2px 2px 0;
    transform: translate(-50%, -50%) rotate(45deg);
    opacity: 0;
    animation: checkmark-in 0.3s forwards;
    animation-delay: 0.1s;
  }
  
  @keyframes check-pop {
    0% { transform: scale(1); }
    50% { transform: scale(1.15); }
    100% { transform: scale(1); }
  }
  
  @keyframes checkmark-in {
    0% { opacity: 0; transform: translate(-50%, -50%) rotate(45deg) scale(0.5); }
    100% { opacity: 1; transform: translate(-50%, -50%) rotate(45deg) scale(1); }
  }
</style>
</head>
<body>
