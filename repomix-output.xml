  padding: 10px 12px; font-family: Inter, sans-serif; width: 100%;
  box-sizing: border-box;
}
.text-input:focus { outline: none; border-color: #c0392b; }

@media (max-width: 600px) {
  .lifts-selector-row {
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
  }

  .lifts-selector-field {
    min-width: 100%;
  }

