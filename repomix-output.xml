}
.session-date-row:hover { background: rgba(255,255,255,0.03); }
.session-date-label {
  font-size: 14px; font-weight: 600;
  color: var(--text-primary, #e8e0d5); flex-shrink: 0;
}
.session-meta {
  font-size: 12px; color: var(--text-secondary, #a09880);
  flex: 1;
}
.session-chevron {
  font-size: 11px; color: var(--text-secondary, #a09880);
  flex-shrink: 0;
}
.session-sets {
  border-top: 1px solid rgba(255,255,255,0.06);
  padding: 0 16px 10px;
}
.set-row {
  display: grid;
  grid-template-columns: 44px 90px 80px 70px 1fr 36px;
  align-items: center; gap: 8px;
  padding: 8px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  font-size: 13px; font-family: Inter, sans-serif;
}
.set-row:last-child { border-bottom: none; }
.set-row-header {
  font-size: 10px; font-weight: 700; letter-spacing: 0.08em;
  color: var(--text-secondary, #a09880); padding: 10px 0 6px;
}
.set-num { color: var(--text-secondary, #a09880); font-weight: 600; }
.set-weight { color: var(--text-primary, #e8e0d5); font-weight: 600; }
.set-reps { color: var(--text-secondary, #a09880); }
.set-rpe { color: var(--text-secondary, #a09880); font-size: 12px; }
.set-note { color: var(--text-secondary, #a09880); font-size: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.set-delete-btn {
  background: none; border: none; color: #6b7280;
  cursor: pointer; font-size: 14px; padding: 4px;
  border-radius: 4px; transition: color 0.15s;
}
.set-delete-btn:hover { color: #c0392b; }

@media (max-width: 600px) {
  .set-row {
    grid-template-columns: 36px 75px 65px 55px 1fr 30px;
    gap: 6px; font-size: 12px;
  }
  .set-row-header { display: none; }
}

/* ── PR Groups ───────────────────────────────────────────── */
.pr-group {
  background: var(--surface, #2a2f35);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px; margin-bottom: 12px; overflow: hidden;
}
.pr-group-header {
  font-size: 12px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--text-primary, #e8e0d5);
  padding: 12px 16px 10px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  background: rgba(255,255,255,0.02);
}
.pr-group-table-header {
  display: grid;
  grid-template-columns: 2fr 90px 110px 70px 100px;
  gap: 8px; padding: 8px 16px;
  font-size: 10px; font-weight: 700; letter-spacing: 0.08em;
  color: var(--text-secondary, #a09880);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.pr-row {
  display: grid;
  grid-template-columns: 2fr 90px 110px 70px 100px;
  gap: 8px; padding: 12px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  font-family: Inter, sans-serif;
  transition: background 0.12s;
  align-items: center;
}
.pr-row:last-child { border-bottom: none; }
.pr-row:hover { background: rgba(255,255,255,0.03); }
.pr-exercise { font-size: 14px; color: var(--text-primary, #e8e0d5); font-weight: 500; }
.pr-1rm { font-size: 15px; font-weight: 700; color: var(--text-primary, #e8e0d5); }
.pr-unit { font-size: 12px; font-weight: 400; color: var(--text-secondary, #a09880); }
.pr-achieved { font-size: 12px; color: var(--text-secondary, #a09880); }
.pr-date { font-size: 12px; color: var(--text-secondary, #a09880); }
.pr-level-badge {
  display: inline-block; font-size: 11px; font-weight: 700;
  padding: 3px 8px; border-radius: 20px;
  text-transform: capitalize; font-family: Inter, sans-serif;
}
@media (max-width: 700px) {
  .pr-group-table-header { display: none; }
  .pr-row {
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 4px;
  }
  .pr-exercise { grid-column: 1; grid-row: 1; font-size: 13px; }
  .pr-1rm { grid-column: 2; grid-row: 1; text-align: right; }
  .pr-achieved { grid-column: 1; grid-row: 2; }
  .pr-date { display: none; }
  .pr-level { grid-column: 2; grid-row: 2; text-align: right; }
}

/* ── Modal ───────────────────────────────────────────────── */
.modal-overlay {
  position: fixed; inset: 0; z-index: 2000;
  background: rgba(0,0,0,0.7);
  display: flex; align-items: center; justify-content: center;
  padding: 16px;
}
.modal-box {
  background: #1e2327; border-radius: 14px;
  border: 1px solid rgba(255,255,255,0.1);
  width: 100%; max-width: 480px;
  max-height: 90vh; overflow-y: auto;
  box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}
.modal-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 20px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.modal-title { font-size: 16px; font-weight: 700; color: var(--text-primary, #e8e0d5); }
.modal-close {
  background: none; border: none; color: var(--text-secondary, #a09880);
  font-size: 18px; cursor: pointer; padding: 4px 8px; border-radius: 6px;
}
.modal-close:hover { color: var(--text-primary, #e8e0d5); }
.modal-body { padding: 16px 20px; }
.modal-footer {
  display: flex; justify-content: flex-end; gap: 10px;
  padding: 14px 20px;
  border-top: 1px solid rgba(255,255,255,0.07);
}
.modal-set-row {
  display: flex; align-items: center; gap: 8px;
  padding: 6px 0;
}
.modal-set-num {
  font-size: 12px; color: var(--text-secondary, #a09880);
  min-width: 40px; font-family: Inter, sans-serif;
}
.set-remove-btn {
  background: none; border: none; color: #6b7280;
  cursor: pointer; font-size: 14px; padding: 4px;
}
.set-remove-btn:hover { color: #c0392b; }
.btn-block { width: 100%; }
.btn-secondary {
  background: rgba(255,255,255,0.08); color: var(--text-primary, #e8e0d5);
  border: 1px solid rgba(255,255,255,0.12); border-radius: 8px;
  padding: 9px 16px; font-size: 13px; font-weight: 600;
  cursor: pointer; font-family: Inter, sans-serif;
  transition: background 0.15s;
}
.btn-secondary:hover { background: rgba(255,255,255,0.12); }

/* ── Empty states ────────────────────────────────────────── */
.empty-state {
  text-align: center; padding: 48px 20px;
  color: var(--text-secondary, #a09880);
  font-family: Inter, sans-serif;
}
.empty-icon { font-size: 2.5rem; margin-bottom: 12px; }
.empty-state p { font-size: 14px; margin-bottom: 16px; }
.empty-row {
  padding: 20px; text-align: center;
  color: var(--text-secondary, #a09880); font-size: 13px;
}

.hide-desktop { display: none !important; }
@media (max-width: 768px) {
  .hide-desktop { display: inline-flex !important; }
  .hide-mobile { display: none !important; }
}
