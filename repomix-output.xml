from app.database import SessionLocal
from app.models import User, WorkoutTemplate
from app.demo_templates import create_demo_templates

def main():
    print("Connecting to DB...")
    db = SessionLocal()
    
    users = db.query(User).all()
    print(f"Found {len(users)} users. Updating demo templates...")
    
    for user in users:
        print(f"Updating templates for {user.email}...")
        
        # Delete old demo templates
        old_templates = db.query(WorkoutTemplate).filter(
            WorkoutTemplate.user_id == user.id,
            WorkoutTemplate.name.in_(["Push Day", "Pull Day", "Leg Day"])
        ).all()
        
        for t in old_templates:
            db.delete(t)
            
        db.commit()
        
        # Create new ones
        create_demo_templates(db, user.id)
        
    print("Done!")

if __name__ == "__main__":
    main()
</file>

<file path="frontend/css/coach.css">
/* ============================================================
   IRONLOG — AI Coach CSS (coach.css)
   ============================================================ */

#coachPage { display: flex; flex-direction: column; gap: 16px; }

/* ── Cards ───────────────────────────────────────────────── */
.coach-card {
  background: var(--surface, #2a2f35);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 14px;
  padding: 20px;
}
.coach-card-title {
  font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--text-secondary, #a09880);
  margin-bottom: 4px;
}
.coach-card-sub {
  font-size: 13px; color: var(--text-secondary, #a09880); margin-bottom: 14px;
}
.coach-full { grid-column: 1 / -1; }

/* ── Phase Banner ────────────────────────────────────────── */
.phase-banner {
  border-radius: 12px; padding: 14px 16px;
  display: flex; align-items: flex-start; gap: 12px;
  font-family: Inter, sans-serif; font-size: 13px; line-height: 1.4;
}
.phase-banner.phase-1 {
  background: rgba(243,156,18,0.12); border: 1px solid rgba(243,156,18,0.25);
  color: #f39c12;
}
.phase-banner.phase-2 {
  background: rgba(39,174,96,0.1); border: 1px solid rgba(39,174,96,0.25);
  color: #27ae60;
}
.phase-banner strong { display: block; margin-bottom: 2px; font-size: 13px; }
.phase-banner span { color: var(--text-secondary, #a09880); font-size: 12px; }
.phase-icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }
.phase-progress {
  height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px;
  margin-top: 8px; overflow: hidden; min-width: 80px;
}
.phase-progress-bar {
  height: 100%; background: #f39c12; border-radius: 2px;
  transition: width 1s ease;
}

/* ── Advice Card ─────────────────────────────────────────── */
.coach-advice-card {
  background: linear-gradient(135deg, #2a2f35 0%, #2d2320 100%);
  border-color: rgba(192,57,43,0.3);
}
.coach-card-header {
  display: flex; align-items: flex-start; gap: 12px;
}
.coach-icon { font-size: 26px; flex-shrink: 0; }
.coach-header-text { flex: 1; }
.coach-header-text .coach-card-title {
  font-size: 14px; color: var(--text-primary, #e8e0d5); margin-bottom: 2px; text-transform: none; letter-spacing: 0;
}
.coach-btn { flex-shrink: 0; padding: 8px 14px; font-size: 13px; white-space: nowrap; }
.advice-output {
  margin-top: 16px; padding-top: 16px;
  border-top: 1px solid rgba(255,255,255,0.07);
  max-height: 420px; overflow-y: auto;
}
.advice-text {
  font-family: Inter, sans-serif; font-size: 14px;
  line-height: 1.75; color: var(--text-primary, #e8e0d5);
}
.advice-text strong { color: #fff; font-weight: 600; }
.advice-cursor {
  display: inline-block; color: #c0392b;
  animation: blink 0.9s step-end infinite;
}
@keyframes blink { 50% { opacity: 0; } }

/* ── Loading / Empty ─────────────────────────────────────── */
.coach-loading {
  display: flex; align-items: center; gap: 14px;
  padding: 20px; color: var(--text-secondary, #a09880);
  font-size: 14px; font-family: Inter, sans-serif;
}
.coach-empty {
  flex-direction: column; align-items: center; text-align: center;
  gap: 12px; padding: 48px 20px;
}
.coach-empty h3 { font-size: 18px; margin: 0; color: var(--text-primary, #e8e0d5); }
.coach-empty p { font-size: 13px; color: var(--text-secondary, #a09880); max-width: 280px; margin: 0; line-height: 1.5; }

/* ── ML Grid ─────────────────────────────────────────────── */
#mlGrid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
@media (max-width: 640px) {
  #mlGrid { grid-template-columns: 1fr; }
  .coach-full { grid-column: 1; }
}

/* ── Consistency ─────────────────────────────────────────── */
.consistency-wrap {
  position: relative; width: 110px; height: 110px; margin: 16px auto 12px;
}
.consistency-ring { width: 110px; height: 110px; }
.consistency-score-overlay {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  font-family: Inter, sans-serif;
}
.consistency-score-overlay span { font-size: 26px; font-weight: 800; color: var(--text-primary, #e8e0d5); line-height: 1; }
.consistency-score-overlay small { font-size: 11px; color: var(--text-secondary, #a09880); }
.consistency-stats { margin-top: 4px; }
.srow {
  display: flex; justify-content: space-between; align-items: center;
  padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.05);
  font-size: 12px; font-family: Inter, sans-serif; color: var(--text-secondary, #a09880);
}
.srow:last-child { border-bottom: none; }
.srow strong { color: var(--text-primary, #e8e0d5); font-size: 13px; }
.cflags { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 10px; }
.cflag {
  font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 20px; font-family: Inter, sans-serif;
}
.cflag.red { background: rgba(192,57,43,0.2); color: #e05a4a; }
.cflag.yellow { background: rgba(243,156,18,0.15); color: #f39c12; }
.cflag.green { background: rgba(39,174,96,0.15); color: #27ae60; }

/* ── Phase tags & pills ──────────────────────────────────── */
.phase-tag { margin-bottom: 10px; }
.phase-tag-pill, .phase-pill {
  display: inline-block; font-size: 10px; font-weight: 700;
  padding: 2px 8px; border-radius: 20px; font-family: Inter, sans-serif;
}
.phase-tag-pill.p1, .phase-pill.p1 { background: rgba(243,156,18,0.15); color: #f39c12; }
.phase-tag-pill.p2, .phase-pill.p2 { background: rgba(39,174,96,0.12); color: #27ae60; }

/* ── Trend row ───────────────────────────────────────────── */
.trend-row { margin-bottom: 12px; display: flex; align-items: center; }

/* ── Prediction boxes ────────────────────────────────────── */
.pred-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin: 10px 0;
}
.pred-grid-3 {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin: 8px 0;
}
.pred-box {
  background: rgba(0,0,0,0.2); border-radius: 8px;
  padding: 10px 6px; text-align: center; font-family: Inter, sans-serif;
}
.pred-box.sm { padding: 6px 4px; }
.pred-val { font-size: 15px; font-weight: 700; color: var(--text-primary, #e8e0d5); }
.pred-box.sm .pred-val { font-size: 13px; }
.pred-lbl { font-size: 10px; color: var(--text-secondary, #a09880); text-transform: uppercase; letter-spacing: 0.04em; margin-top: 2px; }

/* ── Coach note ──────────────────────────────────────────── */
.coach-note { font-size: 12px; color: var(--text-secondary, #a09880); font-style: italic; line-height: 1.5; }

/* ── Strength rows ───────────────────────────────────────── */
.strength-row {
  padding: 14px 0; border-bottom: 1px solid rgba(255,255,255,0.05);
  font-family: Inter, sans-serif;
}
.strength-row:last-child { border-bottom: none; }
.strength-top { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; flex-wrap: wrap; }
.strength-name { font-size: 14px; color: var(--text-primary, #e8e0d5); }
.strength-badge {
  font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 20px; text-transform: uppercase;
}
.strength-badge.improving { background: rgba(39,174,96,0.15); color: #27ae60; }
.strength-badge.plateau { background: rgba(243,156,18,0.15); color: #f39c12; }
.strength-badge.declining { background: rgba(192,57,43,0.15); color: #e05a4a; }
.strength-now { font-size: 13px; color: var(--text-secondary, #a09880); margin-bottom: 8px; }
.strength-now strong { color: var(--text-primary, #e8e0d5); }
.strength-meta { font-size: 11px; color: var(--text-secondary, #a09880); margin-top: 4px; }

/* ── Volume bars ─────────────────────────────────────────── */
.vol-row { padding: 10px 0; font-family: Inter, sans-serif; }
.vol-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
.vol-name { font-size: 13px; font-weight: 600; color: var(--text-primary, #e8e0d5); text-transform: capitalize; }
.vol-change { font-size: 12px; font-weight: 600; }
.vol-bar-bg { height: 6px; background: rgba(255,255,255,0.08); border-radius: 3px; overflow: hidden; margin-bottom: 4px; }
.vol-bar { height: 100%; border-radius: 3px; transition: width 1s ease; min-width: 4px; }
.vol-nums { font-size: 12px; color: var(--text-secondary, #a09880); }
.vol-prev { opacity: 0.65; }
</file>

<file path="frontend/css/mobile.css">
/* ============================================================
   IRONLOG — Mobile / PWA CSS (FULL REPLACEMENT for mobile.css)
   ============================================================ */

/* ─── PWA Install Banner ─────────────────────────────────────────────────── */
#ironlog-install-banner {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  z-index: 9999;
  background: var(--surface, #2a2f35);
  border-top: 2px solid #c0392b;
  padding: 12px 16px;
  display: none;
  box-shadow: 0 -4px 16px rgba(0,0,0,0.4);
}
.pwa-banner-content {
  display: flex; align-items: center; gap: 12px;
  max-width: 600px; margin: 0 auto; width: 100%;
}
.pwa-banner-icon { width: 48px; height: 48px; border-radius: 12px; flex-shrink: 0; }
.pwa-banner-text {
  flex: 1; display: flex; flex-direction: column; gap: 2px;
  font-family: Inter, sans-serif; color: var(--text-primary, #e8e0d5);
}
.pwa-banner-text strong { font-size: 14px; }
.pwa-banner-text span { font-size: 12px; color: var(--text-secondary, #a09880); }
.pwa-banner-actions { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
.pwa-btn-install {
  background: #c0392b; color: #fff; border: none; border-radius: 8px;
  padding: 8px 16px; font-size: 13px; font-weight: 600; cursor: pointer;
  white-space: nowrap; font-family: Inter, sans-serif;
}
.pwa-btn-dismiss {
  background: transparent; border: none;
  color: var(--text-secondary, #a09880); font-size: 18px; cursor: pointer; padding: 4px 8px;
}

/* ─── Safe Area ──────────────────────────────────────────────────────────── */
:root {
  --safe-top: env(safe-area-inset-top, 0px);
  --safe-bottom: env(safe-area-inset-bottom, 0px);
  --mobile-topbar-h: 56px;
  --bottom-nav-h: 60px;
}

/* ─── Loading Overlay ────────────────────────────────────────────────────── */
#ironlog-loading {
  position: fixed; inset: 0; z-index: 99999;
  background: var(--surface-2, #1e2327);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 20px;
  transition: opacity 0.3s ease;
}
#ironlog-loading.hidden { opacity: 0; pointer-events: none; }
.ironlog-spinner {
  width: 48px; height: 48px;
  border: 4px solid rgba(192,57,43,0.2);
  border-top-color: #c0392b;
  border-radius: 50%;
  animation: ironlog-spin 0.8s linear infinite;
}
@keyframes ironlog-spin { to { transform: rotate(360deg); } }
.ironlog-loading-text {
  font-family: Inter, sans-serif; font-size: 13px;
  color: var(--text-secondary, #a09880); letter-spacing: 0.04em;
}

/* ─── Brand logo (sidebar) ───────────────────────────────────────────────── */
.brand-with-logo {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none; flex: 1;
}
.brand-logo-icon {
  width: 32px; height: 32px; border-radius: 8px;
  background: #2a2f35;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; border: 1px solid rgba(255,255,255,0.08);
}
.brand-logo-icon svg { width: 20px; height: 20px; }

/* ─── Mobile Top Bar (hamburger) — hidden on desktop ────────────────────── */
.mobile-topbar { display: none; }
.drawer-backdrop { display: none; }
.mobile-drawer { display: none; }
.mobile-bottom-nav { display: none; }

/* ─── MOBILE ONLY ────────────────────────────────────────────────────────── */
@media (max-width: 768px) {

  /* Hide desktop sidebar */
  .sidebar { display: none !important; }

  /* Main content: account for top bar + bottom nav */
  .main-content, main, .content, #content {
    margin-left: 0 !important;
    padding-top: calc(var(--mobile-topbar-h) + 16px) !important;
    padding-left: 16px !important;
    padding-right: 16px !important;
    padding-bottom: calc(var(--bottom-nav-h) + var(--safe-bottom) + 16px) !important;
    max-width: 100% !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }

  /* ── Mobile Top Bar ─────────────────────────────────────────────────── */
  .mobile-topbar {
    display: flex;
    align-items: center;
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    height: var(--mobile-topbar-h);
    background: var(--surface-2, #1e2327);
    border-bottom: 1px solid var(--border, rgba(255,255,255,0.07));
    padding: 0 16px;
    padding-top: var(--safe-top);
    gap: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }

  .hamburger-btn {
    background: none; border: none;
    color: var(--text-primary, #e8e0d5); cursor: pointer;
    padding: 8px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    -webkit-tap-highlight-color: transparent;
    min-width: 44px; min-height: 44px;
  }
  .hamburger-btn:active { background: var(--border, rgba(255,255,255,0.08)); }

  .mobile-topbar-brand {
    display: flex; align-items: center; gap: 8px;
    text-decoration: none; flex: 1;
  }
  .mobile-brand-name {
    font-family: Inter, sans-serif; font-weight: 700;
    font-size: 17px; color: var(--text-primary, #e8e0d5); letter-spacing: 0.04em;
  }
  .mobile-topbar-spacer { width: 44px; }

  /* ── Backdrop ───────────────────────────────────────────────────────── */
  .drawer-backdrop {
    display: block;
    position: fixed; inset: 0;
    z-index: 1100;
    background: rgba(0,0,0,0.6);
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s ease;
    -webkit-backdrop-filter: blur(2px);
    backdrop-filter: blur(2px);
  }
  .drawer-backdrop.open { opacity: 1; pointer-events: auto; }

  /* ── Slide-in Drawer ────────────────────────────────────────────────── */
  .mobile-drawer {
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0; bottom: 0;
    width: 280px;
    z-index: 1200;
    background: var(--surface-2, #1e2327);
    border-right: 1px solid var(--border, rgba(255,255,255,0.08));
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 4px 0 24px rgba(0,0,0,0.5);
    padding-top: var(--safe-top);
    overflow-y: auto;
  }
  .mobile-drawer.open { transform: translateX(0); }

  /* Drawer Header */
  .drawer-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 16px 16px;
    border-bottom: 1px solid var(--border, rgba(255,255,255,0.07));
  }
  .drawer-brand { display: flex; align-items: center; gap: 10px; }
  .drawer-brand-text {
    display: flex; flex-direction: column; gap: 1px;
  }
  .drawer-brand-text strong {
    font-family: Inter, sans-serif; font-weight: 700;
    font-size: 16px; color: var(--text-primary, #e8e0d5); letter-spacing: 0.04em;
  }
  .drawer-brand-text span {
    font-family: Inter, sans-serif; font-size: 11px;
    color: var(--text-secondary, #a09880); text-transform: uppercase; letter-spacing: 0.08em;
  }

  .drawer-close-btn {
    background: none; border: none;
    color: var(--text-secondary, #a09880); cursor: pointer; padding: 8px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    min-width: 44px; min-height: 44px;
    -webkit-tap-highlight-color: transparent;
  }
  .drawer-close-btn:active { background: var(--border, rgba(255,255,255,0.08)); }

  /* Drawer Nav Links */
  .drawer-nav {
    flex: 1; padding: 12px 0;
    display: flex; flex-direction: column;
  }
  .drawer-link {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 20px;
    color: var(--text-secondary, #a09880); text-decoration: none;
    font-family: Inter, sans-serif; font-size: 15px; font-weight: 500;
    border-left: 3px solid transparent;
    transition: color 0.15s, background 0.15s;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .drawer-link svg { width: 20px; height: 20px; flex-shrink: 0; }
  .drawer-link:active { background: var(--border, rgba(255,255,255,0.05)); }
  .drawer-link.active {
    color: #c0392b;
    background: rgba(192,57,43,0.08);
    border-left-color: #c0392b;
  }

  /* Drawer Footer */
  .drawer-footer {
    border-top: 1px solid var(--border, rgba(255,255,255,0.07));
    padding: 12px 0;
    padding-bottom: calc(12px + var(--safe-bottom));
  }
  .drawer-link-logout { color: #e05a4a !important; }
  .drawer-link-logout:active { background: rgba(192,57,43,0.1) !important; }

  /* ── Bottom Navigation Bar ──────────────────────────────────────────── */
  .mobile-bottom-nav {
    display: flex;
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 1000;
    background: var(--surface-2, #1e2327);
    border-top: 1px solid var(--border, rgba(255,255,255,0.08));
    padding-bottom: var(--safe-bottom);
    box-shadow: 0 -4px 20px rgba(0,0,0,0.3);
    height: calc(var(--bottom-nav-h) + var(--safe-bottom));
  }
  .bottom-nav-link {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 8px 4px;
    color: var(--text-tertiary, #6b7280);
    text-decoration: none;
    font-size: 10px; font-family: Inter, sans-serif;
    gap: 3px;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.15s;
    min-height: 44px;
  }
  .bottom-nav-link svg { width: 22px; height: 22px; }
  .bottom-nav-link.active { color: #c0392b; }
  .bottom-nav-link:active { color: #c0392b; }

  /* ── Page header adjustments ────────────────────────────────────────── */
  .page-header h1 { font-size: 22px !important; }

  /* ── Cards full width ───────────────────────────────────────────────── */
  .stats-grid, .grid, .cards-row, .dash-grid {
    grid-template-columns: 1fr !important;
    gap: 12px !important;
  }

  /* ── Charts ─────────────────────────────────────────────────────────── */
  canvas { max-height: 260px !important; }

  /* ── Forms ───────────────────────────────────────────────────────────── */
  input[type="text"], input[type="number"], input[type="email"],
  input[type="password"], input[type="date"], select, textarea {
    width: 100% !important;
    font-size: 16px !important;
    padding: 12px !important;
    box-sizing: border-box !important;
  }

  /* ── Tables ──────────────────────────────────────────────────────────── */
  .table-wrapper, table {
    overflow-x: auto; display: block;
    -webkit-overflow-scrolling: touch;
  }

  /* ── Modals ──────────────────────────────────────────────────────────── */
  .modal, dialog {
    width: 100% !important; max-width: 100% !important;
    margin: 0 !important; border-radius: 16px 16px 0 0 !important;
    position: fixed !important; bottom: 0 !important; top: auto !important;
    max-height: 90vh; overflow-y: auto;
  }
}

/* ─── Standalone PWA (installed on phone) ────────────────────────────────── */
@media (display-mode: standalone) {
  body { padding-top: var(--safe-top); }
  #ironlog-install-banner, #ironlog-ios-hint { display: none !important; }
}

/* ─── Touch targets ─────────────────────────────────────────────────────── */
@media (pointer: coarse) {
  a, button, [role="button"], label, select,
  input[type="checkbox"], input[type="radio"] {
    min-height: 44px; min-width: 44px;
  }
}

/* ─── Offline / Update banners ───────────────────────────────────────────── */
#ironlog-offline-banner {
  position: fixed; top: 0; left: 0; right: 0; z-index: 10000;
  background: #e67e22; color: #fff; text-align: center;
  padding: 8px 16px; font-size: 14px; font-family: Inter, sans-serif;
  display: none;
}
</file>

<file path="frontend/css/polish.css">
/* ============================================================
   IRONLOG — Polish CSS
   Onboarding modal + Skeleton screens
   Link AFTER style.css and mobile.css on all inner pages
   ============================================================ */

/* ─── Skeleton Screens ───────────────────────────────────────────────────── */

/* Shimmer animation */
@keyframes sk-shimmer {
  0%   { background-position: -800px 0; }
  100% { background-position: 800px 0; }
}

.sk-wrapper {
  animation: sk-fadein 0.2s ease;
}
@keyframes sk-fadein { from { opacity: 0; } to { opacity: 1; } }
.sk-wrapper.sk-fadeout {
  animation: sk-fadeout 0.3s ease forwards;
}
@keyframes sk-fadeout { to { opacity: 0; } }

.sk-page { display: flex; flex-direction: column; gap: 0; }

/* Base shimmer element */
.sk-line, .sk-card, .sk-card-inner, .sk-input, .sk-btn,
.sk-chart, .sk-scale, .sk-ring, .sk-pill, .sk-circle,
.sk-vol-bar {
  background: linear-gradient(
    90deg,
    #2a2f35 0px,
    #343b43 40%,
    #2a2f35 80%
  );
  background-size: 800px 100%;
  animation: sk-shimmer 1.5s infinite linear;
  border-radius: 6px;
}

/* Cards */
.sk-card {
  background: var(--surface, #2a2f35);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 12px;
  padding: 18px;
  animation: none; /* card itself doesn't shimmer, children do */
}
.sk-card-inner {
  border-radius: 8px; padding: 10px; background: rgba(255,255,255,0.03);
  animation: none;
}

/* Lines */
.sk-line       { height: 12px; border-radius: 4px; }
.sk-line-sm    { width: 40%; }
.sk-line-md    { width: 60%; }
.sk-line-lg    { width: 75%; }
.sk-line-full  { width: 100%; }
.sk-line-xl    { width: 55%; height: 28px; border-radius: 6px; }

/* Spacing helpers */
.sk-mt4  { margin-top: 4px; }
.sk-mt6  { margin-top: 6px; }
.sk-mt8  { margin-top: 8px; }
.sk-mt10 { margin-top: 10px; }
.sk-mt12 { margin-top: 12px; }
.sk-mt16 { margin-top: 16px; }

/* Grids */
.sk-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.sk-grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; }
.sk-grid-4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; margin-bottom: 16px; }

@media (max-width: 768px) {
  .sk-grid-4 { grid-template-columns: 1fr 1fr; }
  .sk-grid-3 { grid-template-columns: 1fr 1fr 1fr; }
  .sk-grid-2 { grid-template-columns: 1fr; }
}
@media (max-width: 500px) {
  .sk-grid-4 { grid-template-columns: 1fr; }
  .sk-grid-3 { grid-template-columns: 1fr; }
}

/* Specific shapes */
.sk-chart    { height: 200px; border-radius: 8px; }
.sk-scale    { height: 12px; border-radius: 6px; width: 100%; }
.sk-ring     { width: 110px; height: 110px; border-radius: 50%; margin: 0 auto; }
.sk-circle   { width: 40px; height: 40px; border-radius: 50%; margin: 0 auto; }
.sk-input    { height: 42px; border-radius: 8px; }
.sk-btn      { height: 40px; border-radius: 8px; width: 120px; }
.sk-vol-bar  { height: 8px; border-radius: 4px; width: 100%; }
.sk-pills    { display: flex; flex-wrap: wrap; gap: 8px; }
.sk-pill     { height: 34px; width: 90px; border-radius: 20px; }
.sk-row      { display: flex; justify-content: space-between; align-items: center; }
.sk-session-row { border-bottom: 1px solid rgba(255,255,255,0.04); padding-bottom: 10px; }


/* ─── Onboarding Modal ────────────────────────────────────────────────────── */

.ob-overlay {
  position: fixed; inset: 0; z-index: 10000;
  background: rgba(0,0,0,0.75);
  display: flex; align-items: center; justify-content: center;
  padding: 16px;
  animation: ob-fadein 0.3s ease;
  -webkit-backdrop-filter: blur(4px);
  backdrop-filter: blur(4px);
}
@keyframes ob-fadein { from { opacity: 0; } to { opacity: 1; } }
.ob-overlay.ob-fadeout { animation: ob-fadeout 0.4s ease forwards; }
@keyframes ob-fadeout { to { opacity: 0; } }

.ob-modal {
  background: #1e2327;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 18px;
  width: 100%; max-width: 480px;
  max-height: 92vh; overflow-y: auto;
  box-shadow: 0 24px 80px rgba(0,0,0,0.6);
  animation: ob-slidein 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes ob-slidein {
  from { opacity: 0; transform: translateY(30px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* Progress bar */
.ob-progress {
  height: 4px; background: rgba(255,255,255,0.08);
  border-radius: 4px 4px 0 0; overflow: hidden;
}
.ob-progress-bar {
  height: 100%; background: #c0392b;
  transition: width 0.4s ease; border-radius: 4px;
}

/* Step dots */
.ob-steps {
  display: flex; align-items: center; justify-content: center;
  gap: 0; padding: 20px 24px 0;
}
.ob-step {
  width: 28px; height: 28px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700; font-family: Inter, sans-serif;
  background: rgba(255,255,255,0.08);
  color: #6b7280; border: 2px solid rgba(255,255,255,0.1);
  transition: all 0.3s;
  flex-shrink: 0;
}
.ob-step.active {
  background: #c0392b; color: #fff; border-color: #c0392b;
  box-shadow: 0 0 0 4px rgba(192,57,43,0.2);
}
.ob-step.done {
  background: rgba(192,57,43,0.2); color: #c0392b;
  border-color: rgba(192,57,43,0.4);
}
.ob-step.done span::before { content: "✓"; }
.ob-step.done span { font-size: 0; }
.ob-step.done span::before { font-size: 12px; }
.ob-step-line {
  flex: 1; height: 2px; background: rgba(255,255,255,0.08);
  max-width: 60px;
}

/* Step content */
.ob-step-content {
  padding: 24px 28px 28px;
  font-family: Inter, sans-serif;
}
@media (max-width: 480px) {
  .ob-step-content { padding: 20px; }
}

.ob-emoji {
  font-size: 42px; text-align: center; margin-bottom: 12px; line-height: 1;
}
.ob-emoji-big { font-size: 64px; margin-bottom: 16px; }

.ob-title {
  font-size: 22px; font-weight: 800;
  color: var(--text-primary, #e8e0d5);
  text-align: center; margin: 0 0 8px;
}
.ob-subtitle {
  font-size: 14px; color: var(--text-secondary, #a09880);
  text-align: center; line-height: 1.5;
  margin: 0 0 24px;
}

/* Form fields */
.ob-form { display: flex; flex-direction: column; gap: 14px; }
.ob-field { display: flex; flex-direction: column; gap: 5px; flex: 1; }
.ob-field-row { display: flex; gap: 12px; }
@media (max-width: 400px) { .ob-field-row { flex-direction: column; } }

.ob-label {
  font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--text-secondary, #a09880);
}

.ob-input-group {
  display: flex; align-items: center;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px; overflow: hidden;
  transition: border-color 0.15s;
}
.ob-input-group:focus-within { border-color: #c0392b; }
.ob-input-large { border-radius: 12px; }

.ob-input {
  flex: 1; background: transparent; border: none;
  color: var(--text-primary, #e8e0d5); font-size: 15px;
  padding: 11px 12px; font-family: Inter, sans-serif;
  outline: none; width: 100%;
}
/* Standalone input (no suffix) */
.ob-field > .ob-input {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
}
.ob-field > .ob-input:focus { border-color: #c0392b; outline: none; }

.ob-input-big { font-size: 24px; font-weight: 700; padding: 14px 16px; }
.ob-input-suffix {
  padding: 0 12px; color: #6b7280; font-size: 13px;
  font-family: Inter, sans-serif; white-space: nowrap;
  border-left: 1px solid rgba(255,255,255,0.07);
}
.ob-suffix-big { font-size: 18px; padding: 0 16px; }

.ob-select {
  width: 100%; background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1); border-radius: 10px;
  color: var(--text-primary, #e8e0d5); font-size: 14px;
  padding: 11px 12px; font-family: Inter, sans-serif; cursor: pointer;
}
.ob-select:focus { outline: none; border-color: #c0392b; }

.ob-radio-group {
  display: flex; gap: 16px; flex-wrap: wrap;
}
.ob-radio {
  display: flex; align-items: center; gap: 7px;
  font-size: 14px; color: var(--text-primary, #e8e0d5);
  cursor: pointer;
}
.ob-radio input { accent-color: #c0392b; width: 16px; height: 16px; cursor: pointer; }

.ob-tip {
  background: rgba(201,168,76,0.08);
  border: 1px solid rgba(201,168,76,0.2);
  border-radius: 10px; padding: 12px 14px;
  font-size: 13px; color: #c9a84c; line-height: 1.5;
}
.ob-tip strong { color: #e0bc60; }

/* Error */
.ob-error {
  font-size: 13px; color: #e05a4a; min-height: 18px;
  font-family: Inter, sans-serif; margin-top: 4px;
}

/* Actions */
.ob-actions {
  display: flex; align-items: center; justify-content: flex-end;
  gap: 10px; margin-top: 24px; flex-wrap: wrap;
}
.ob-actions-center { justify-content: center; }

.ob-btn-primary {
  background: #c0392b; color: #fff; border: none;
  border-radius: 10px; padding: 11px 22px;
  font-size: 14px; font-weight: 700; cursor: pointer;
  font-family: Inter, sans-serif; transition: opacity 0.15s;
  white-space: nowrap;
}
.ob-btn-primary:hover { opacity: 0.88; }
.ob-btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
.ob-btn-wide { padding: 13px 40px; font-size: 15px; }

.ob-btn-skip {
  background: transparent; color: var(--text-secondary, #a09880);
  border: none; font-size: 13px; cursor: pointer;
  font-family: Inter, sans-serif; padding: 8px 4px;
  text-decoration: underline; text-underline-offset: 3px;
}
.ob-btn-skip:hover { color: var(--text-primary, #e8e0d5); }

.ob-btn-ghost {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  color: var(--text-secondary, #a09880);
  border-radius: 10px; padding: 10px 16px;
  font-size: 13px; cursor: pointer;
  font-family: Inter, sans-serif;
}
.ob-btn-ghost:hover { background: rgba(255,255,255,0.1); }

/* Done screen */
.ob-done { text-align: center; }
.ob-done-tips {
  display: flex; flex-direction: column; gap: 10px;
  margin: 20px 0; text-align: left;
}
.ob-done-tip {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 10px; padding: 12px 16px;
  font-size: 14px; color: var(--text-secondary, #a09880);
  font-family: Inter, sans-serif;
}
.ob-done-tip strong { color: var(--text-primary, #e8e0d5); }
