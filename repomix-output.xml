<file path="frontend/reset-password.html">
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#1e2327">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="IRONLOG">
<link rel="apple-touch-icon" href="/icons/icon-192.png">
<link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png">
<link rel="stylesheet" href="/css/mobile.css?v=104">
<title>Reset Password — IRONLOG</title>
<link rel="stylesheet" href="css/style.css?v=104">
</head>
<body>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="brand-mark">IL</div>
      <h1>Choose a new password</h1>
      <p>This link is valid for 1 hour and works once.</p>
    </div>

    <div id="alertSlot"></div>

    <form id="resetForm">
      <div class="field">
        <label for="rpPassword">New password</label>
        <input id="rpPassword" type="password" autocomplete="new-password" minlength="6" required>
        <span class="hint">At least 6 characters.</span>
      </div>
      <div class="field">
        <label for="rpConfirm">Confirm new password</label>
        <input id="rpConfirm" type="password" autocomplete="new-password" minlength="6" required>
      </div>
      <button class="btn btn-primary btn-block" type="submit" id="rpSubmitBtn">Reset password</button>
    </form>

    <div id="successWrap" style="display:none;text-align:center;">
      <a href="login.html" class="btn btn-primary btn-block">Go to log in</a>
    </div>

    <div class="auth-switch">
      <a href="forgot-password.html">Request a new reset link</a>
    </div>
  </div>
</div>

<script src="js/config.js?v=104"></script>
<script src="js/api.js?v=104"></script>
<script>
const resetForm = document.getElementById("resetForm");
const alertSlot = document.getElementById("alertSlot");
const params = new URLSearchParams(window.location.search);
const token = params.get("token");

function setAlert(message, type = "error") {
  alertSlot.innerHTML = message ? `<div class="alert alert-${type}">${message}</div>` : "";
}

if (!token) {
  resetForm.style.display = "none";
  setAlert("This reset link is missing its token. Please request a new one.");
}

resetForm.addEventListener("submit", async (e) => {
  e.preventDefault();
  setAlert("");
  const password = document.getElementById("rpPassword").value;
  const confirm = document.getElementById("rpConfirm").value;
  if (password !== confirm) {
    setAlert("Passwords don't match.");
    return;
  }
  const btn = document.getElementById("rpSubmitBtn");
  btn.disabled = true; btn.textContent = "Resetting…";
  try {
    await Api.resetPassword(token, password);
    resetForm.style.display = "none";
    document.getElementById("successWrap").style.display = "block";
    setAlert("Password reset. You can log in with your new password now.", "success");
  } catch (err) {
    setAlert(err.message || "This reset link is invalid or has expired.");
    btn.disabled = false; btn.textContent = "Reset password";
  }
});
</script>
<script src="/js/pwa.js?v=104"></script>
</body>
</html>
</file>

<file path="frontend/verify-email.html">
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#1e2327">
<title>Verify Email — IRONLOG</title>
<link rel="stylesheet" href="css/style.css?v=104">
<link rel="stylesheet" href="css/mobile.css?v=104">
</head>
<body>
<div class="auth-page">
  <div class="auth-card" style="text-align: center;">
    <div class="auth-brand">
      <div class="brand-mark">IL</div>
      <h1>IRONLOG</h1>
    </div>

    <h2 style="margin-bottom: 16px;">Email Verification</h2>
    
    <div id="alertSlot">
      <div class="alert alert-info">Verifying your email address... Please wait.</div>
    </div>

    <div style="margin-top: 24px;">
      <a href="login.html" class="btn btn-primary" style="display:inline-block;">Go to Login</a>
    </div>
  </div>
</div>

<script src="js/config.js?v=104"></script>
<script src="js/api.js?v=104"></script>
<script>
async function verifyEmail() {
  const urlParams = new URLSearchParams(window.location.search);
  const token = urlParams.get("token");
  const alertSlot = document.getElementById("alertSlot");

  if (!token) {
    alertSlot.innerHTML = `<div class="alert alert-error">No verification token found in the URL.</div>`;
    return;
  }

  try {
    const res = await Api.verifyEmail(token);
    alertSlot.innerHTML = `<div class="alert alert-success">${res.message || "Email successfully verified!"}</div>`;
  } catch (err) {
    alertSlot.innerHTML = `<div class="alert alert-error">${err.message || "Verification failed. The link might be invalid or expired."}</div>`;
  }
}

window.addEventListener("load", verifyEmail);
</script>
</body>
</html>
